  inTaskContexts:
  - id: default
    text: Let's have fun together!
    options:
    - id: Fail
      nextOption: pauseOpt
      label: Mercy
      action: PauseTask
      side: 0
  - id: pauseOpt
    text: Yes you can have a rest..
    options:
    - id: Cont
      nextOption: greenDefault
      label: Im ready.
      action: ContinueTask
      side: 0
  - id: stop
    text: Do you want to stop session
    options:
    - id: Yes
      nextOption: 
      label: Yes.
      action: EndSession
      side: 1
    - id: No
      nextOption: default
      label: No
      action: ContinueTask
      side: 0
  - id: greenDefault
    text: Just stroke as i show you!
    options:
    - id: Mercy
      nextOption: pauseOpt
      label: Mercy
      action: PauseTask
      side: 1
    - id: failedOptionId
      nextOption: ' '
      label: Failed
      action: Failed
      side: 1
  - id: redDefault
    text: My turn. Relax and DONT TOUCH yourself!
    options:
    - id: failedOptionId
      nextOption: ' '
      label: Failed
      action: Failed
      side: 1
  - id: f_fail
    text: No. If you fail again, we stop.
    options:
    - id: f_fail_1
      nextOption: ' '
      label: Sorry
      action: ContinueTask
      side: 0
    - id: f_fail_2
      nextOption: ' '
      label: Go next
      action: NextTask_fail
      side: 1
  - id: s_fail
    text: You have failed again! Pussy!
    options:
    - id: f_fail_1
      nextOption: ' '
      label: Sorry
      action: NextTask_fail
      side: 0
