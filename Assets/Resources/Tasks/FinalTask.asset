  m_Script: {fileID: 11500000, guid: d38bf9db2ff1ede42a59ffec63f8a803, type: 3}
  m_Name: FinalTask
  m_EditorClassIdentifier: 
  inTaskContexts:
  - id: FT_buildup
    text: Build up your edge. Let me know when you are there!
    options:
    - id: Fail
      nextOption: 
      label: Mercy
      action: FT_Mercy
      side: 1
    - id: OnEdge
      nextOption: 
      label: Edged
      action: OnEdge
      side: 0
  - id: FT_S2V1
    text: I let you finish. In 10 seconds!
    options:
    - id: Finished
      nextOption: 
      label: Cumming
      action: FT_Finished
      side: 0
  - id: FT_S2V2_Prep
    text: Ok. I give you chance to finish! Exactly in 10 seconds.
    options:
    - id: FT_now
      nextOption: 
      label: Now
      action: FT_NoOp
      side: 0
  - id: FT_S2V2_Main
    text: '"HANDS OFF! RUIN IT!'
    options:
    - id: FT_Ruin
      nextOption: 
      label: I ruined
      action: FT_Ruin
      side: 0
    - id: FT_S2_Fail
      nextOption: 
      label: I failed
      action: FT_Failed
      side: 1
  - id: FT_S2V3_1
    text: Useless. The last and only chance to finish
    options:
    - id: FT_thank
      nextOption: 
      label: Thank you
      action: ContinueTask
      side: 0
  - id: FT_S2V3_2
    text: Loose it in 10 SECOND!
    options:
    - id: FT_now
      nextOption: 
      label: Now
      action: FT_NoOp
      side: 0
  - id: FT_S2V3_3
    text: Did you really think I let you after your fail! No!
    options:
    - id: FT_noop
      nextOption: 
      label: Sorry
      action: FT_V3_Continue_3
      side: 0
  - id: FT_S2V3_4
    text: Now clean yourself. And... do whatever you want. Bye
    options:
    - id: FT_noop
      nextOption: 
      label: Sorry
      action: FT_V3_Continue_4
      side: 0
  - id: FT_cooldown
    text: Now cool down for a moment
    options:
    - id: FT_cd_timer
      nextOption: 
      label: 10
      action: FT_NoOp
      side: 0
  - id: FT_S2V1_PAUSE
    text: Poor thing, you are not ready. Let me think.
    options:
    - id: opt_sorry
      nextOption: 
      label: Sorry
      action: FT_GoV2Prep
      side: 0
