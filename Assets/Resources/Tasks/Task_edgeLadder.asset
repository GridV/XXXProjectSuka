  inTaskContexts:
  - id: edge_ladder_buildup
    text: Build up your edge. Let me know when you there!
    options:
    - id: Fail
      nextOption: pauseOpt
      label: Mercy
      action: PauseTask
      side: 1
    - id: OnEdge
      nextOption: 
      label: Edged
      action: OnEdge
      side: 0
  - id: pauseOpt
    text: You can rest for NOW... I wont tolerate it next time!
    options:
    - id: Cont
      nextOption: 
      label: I'm ready
      action: ContinueTask
      side: 0
    - id: quit
      nextOption: stop
      label: Stop
      action: stop
      side: 1
  - id: edge_ladder_plateau
    text: Now Hold the edge as long as I want!
    options:
    - id: slipped
      nextOption: 
      label: Slipped
      action: Slipped
      side: 1
    - id: Fail
      nextOption: pauseOpt
      label: Mercy
      action: PauseTask
      side: 1
  - id: stop
    text: Do you want to leave me?
    options:
    - id: yes
      nextOption: 
      label: Yes
      action: EndSession
      side: 1
    - id: No
      nextOption: default
      label: No
      action: ContinueTask
      side: 0
